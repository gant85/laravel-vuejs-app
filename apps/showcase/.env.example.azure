APP_NAME="Showcase Application"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-app.azurewebsites.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Azure Database for MySQL
DB_CONNECTION=mysql
DB_HOST=your-server.mysql.database.azure.com
DB_PORT=3306
DB_DATABASE=hospital
DB_USERNAME=your-username@your-server
DB_PASSWORD=your-password
# Enable SSL for Azure MySQL
MYSQL_ATTR_SSL_CA=/path/to/DigiCertGlobalRootCA.crt.pem

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Azure Cache for Redis
CACHE_STORE=redis
CACHE_PREFIX=hospital_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=your-cache.redis.cache.windows.net
REDIS_PASSWORD=your-redis-password
REDIS_PORT=6380
# Enable SSL for Azure Redis
REDIS_SCHEME=tls

# Azure Mail Service or SendGrid
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Azure Application Insights (optional)
AZURE_APPLICATION_INSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key

# Azure Storage (optional, for file uploads)
# FILESYSTEM_DISK=azure
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
# AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
# AZURE_STORAGE_CONTAINER=uploads
