{
  "name": "@reference-app-laravel-vue/showcase",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm exec vue-tsc && vite build",
    "build:prod": "pnpm exec vue-tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "pnpm exec vue-tsc --noEmit",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,css,scss,json,md}\"",
    "stylelint": "stylelint \"**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss,vue}\" --fix"
  },
  "dependencies": {
    "@fontsource-variable/open-sans": "^5.2.7",
    "@inertiajs/vue3": "^2.1.4",
    "@mdi/font": "^7.4.47",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-web": "^0.41.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.54.2",
    "@opentelemetry/instrumentation": "^0.55.0",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-trace-base": "^1.29.0",
    "@opentelemetry/sdk-trace-web": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "@reference-app-laravel-vue/ui-kit": "workspace:*",
    "axios": "^1.7.9",
    "vue": "^3.5.13",
    "vuetify": "^3.7.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-vue": "^5.2.2",
    "@vitest/ui": "^2.1.8",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.31.0",
    "happy-dom": "^15.11.7",
    "laravel-vite-plugin": "^1.1.1",
    "sass-embedded": "^1.85.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-imagetools": "^9.0.2",
    "vite-plugin-vuetify": "^2.0.4",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.2.0"
  }
}
