APP_NAME="Showcase Application"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Debug Tools
# Laravel Debugbar (shows queries, views, routes in browser)
DEBUGBAR_ENABLED=true

# Laravel Telescope (advanced monitoring at /telescope)
TELESCOPE_ENABLED=true
TELESCOPE_DRIVER=database

# Xdebug Configuration (step-through debugging in VS Code)
# Set XDEBUG_MODE=debug to enable, or off to disable
XDEBUG_MODE=debug
XDEBUG_CLIENT_PORT=9003
XDEBUG_IDE_KEY=VSCODE

# Editor Configuration (for Laravel Debug Bar / Error Pages)
# Use 'vscode' to open files in VS Code, or 'phpstorm' for PHPStorm
IGNITION_EDITOR=vscode
# For Windows: Update with your local path (e.g., C:\Users\YourName\Documents\repo\reference-app-laravel-vue\apps\hospital)
# For Linux/Mac: Comment out this line or update with your path
# IGNITION_LOCAL_SITES_PATH=

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=showcase
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# OpenTelemetry Configuration
OTEL_ENABLED=true
OTEL_SERVICE_NAME=showcase-backend
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_PHP_AUTOLOAD_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
VITE_APP_VERSION=1.0.0
VITE_OTEL_ENABLED=true
VITE_OTEL_SERVICE_NAME=showcase-frontend
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# External API Configuration (BFF Pattern)
# Using JSONPlaceholder as example external API for demo purposes
EXTERNAL_API_BASE_URL=https://jsonplaceholder.typicode.com
EXTERNAL_API_TOKEN=
EXTERNAL_API_TIMEOUT=10
EXTERNAL_API_RETRY_TIMES=3

# Azure Entra ID (Azure Active Directory) Configuration
# Register your app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Steps:
# 1. Create new App Registration in Azure Portal
# 2. Set redirect URI: http://localhost:8000/auth/azure/callback (or your production URL)
# 3. Add API permissions: User.Read, profile, email, openid (Microsoft Graph - Delegated)
# 4. Grant admin consent for permissions
# 5. Create a client secret and copy the value immediately
# 6. Copy Application (client) ID, Directory (tenant) ID, and Client secret value below
# Documentation: docs/AZURE-ENTRA-AUTH.md
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:8000/auth/azure/callback
