{
  "name": "@reference-app-laravel-vue/ui-kit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/ui-kit.umd.js",
  "module": "./dist/ui-kit.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/ui-kit.es.js",
      "require": "./dist/ui-kit.umd.js"
    },
    "./theme": {
      "development": "./src/theme/index.ts",
      "default": "./src/theme/index.ts"
    },
    "./styles": {
      "development": "./src/styles/_index.scss",
      "default": "./src/styles/_index.scss"
    },
    "./overrides": {
      "development": "./src/styles/overrides.scss",
      "default": "./src/styles/overrides.scss"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,css,scss,json,md}\"",
    "stylelint": "stylelint \"**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss,vue}\" --fix"
  },
  "dependencies": {
    "@fontsource-variable/open-sans": "^5.2.7",
    "@mdi/font": "^7.4.47"
  },
  "peerDependencies": {
    "vue": "^3.5.13",
    "vuetify": "^3.7.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-vue": "^5.2.2",
    "@vitest/ui": "^2.1.8",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.31.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.2.0",
    "vite-plugin-dts": "^4.3.0"
  }
}
