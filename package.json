{
  "name": "@reference-app-laravel-vue/root",
  "version": "1.0.0-SNAPSHOT",
  "private": true,
  "description": "POC Full Stack Laravel + Vue + Inertia with Material 3",
  "scripts": {
    "dev": "pnpm --filter @reference-app-laravel-vue/showcase dev",
    "dev:showcase-ui-kit": "pnpm --filter @reference-app-laravel-vue/showcase-ui-kit dev",
    "build": "pnpm -r build",
    "build:prod": "pnpm -r build --mode production",
    "test": "pnpm -r test",
    "test:ui": "pnpm -r test:ui",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "sheriff": "sheriff verify",
    "sheriff:export": "sheriff export",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,css,scss,json,md}\"",
    "stylelint": "stylelint \"**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss,vue}\" --fix",
    "docker:up": "docker compose -f docker-compose.yml -f docker-compose.local.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.local.yml down",
    "docker:logs": "docker compose -f docker-compose.yml -f docker-compose.local.yml logs -f",
    "docker:rebuild": "docker compose -f docker-compose.yml -f docker-compose.local.yml down && docker compose -f docker-compose.yml -f docker-compose.local.yml build && docker compose -f docker-compose.yml -f docker-compose.local.yml up -d",
    "docker:azure:up": "docker compose -f docker-compose.yml -f docker-compose.azure.yml up -d",
    "docker:azure:down": "docker compose -f docker-compose.yml -f docker-compose.azure.yml down",
    "docker:azure:logs": "docker compose -f docker-compose.yml -f docker-compose.azure.yml logs -f",
    "docs:ui-kit": "python scripts/generate_ui_kit_readme.py",
    "docs:ui-kit:check": "python scripts/generate_ui_kit_readme.py --check",
    "docs:confluence": "python scripts/upload_confluence.py",
    "docs:confluence:single": "python scripts/upload_confluence.py --action upload-single",
    "docs:confluence:delete": "python scripts/upload_confluence.py --action delete",
    "docs:confluence:delete-children": "python scripts/upload_confluence.py --action delete-children",
    "prepare": "lefthook install",
    "commitlint": "commitlint --edit",
    "check-versions": "node --version && pnpm --version && echo \"Expected Node: $(cat .node-version)\""
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.6.0",
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "lefthook": "^2.0.15",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "stylelint": "^16.24.0",
    "stylelint-config-recess-order": "^7.3.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-prettier": "^5.0.3",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "vite-imagetools": "^9.0.2",
    "vite-plugin-compression": "^0.5.1",
    "nx": "22.5.0"
  }
}
